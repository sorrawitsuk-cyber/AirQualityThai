{
  "functions": {
    "api/tmd-wind.js": { "maxDuration": 30 },
    "api/cron-wind.js": { "maxDuration": 30 },
    "api/weather-history.js": { "maxDuration": 30 },
    "api/cron-history.js": { "maxDuration": 30 }
  },
  "headers": [
    {
      "source": "/index.html",
      "headers": [{"key": "Cache-Control", "value": "no-store, no-cache, must-revalidate"}]
    },
    {
      "source": "/",
      "headers": [{"key": "Cache-Control", "value": "no-store, no-cache, must-revalidate"}]
    },
    {
      "source": "/sw.js",
      "headers": [{"key": "Cache-Control", "value": "no-store, no-cache, must-revalidate"}]
    },
    {
      "source": "/assets/(.*)",
      "headers": [{"key": "Cache-Control", "value": "public, max-age=31536000, immutable"}]
    }
  ],
  "crons": [
    {
      "path": "/api/cron",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron-wind",
      "schedule": "30 0 * * *"
    },
    {
      "path": "/api/cron-history",
      "schedule": "20 0 * * *"
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
